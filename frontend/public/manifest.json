{
  "manifest_version": 3,
  "name": "AI Interviewer",
  "version": "1.0",
  "description": "DSA AI Interview Assistant",
  "action": {
    "default_popup": "index.html"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://leetcode.com/*"
  ]
}